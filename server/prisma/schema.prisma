generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───

enum UserRole {
  ADMIN
  USER
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  username       String   @unique
  password       String
  avatar         String   @default("")                                // profile picture URL
  role           UserRole @default(USER)
  isActive       Boolean  @default(true) @map("is_active")
  pinUnlockMode  String   @default("per_app") @map("pin_unlock_mode") // "per_app" | "global" | "global_except"
  excludedAppIds Int[]    @default([]) @map("excluded_app_ids")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  purchases    Purchase[]    @relation("UserPurchases")
  assignedPurchases Purchase[] @relation("AssignedByAdmin")
  activityLogs ActivityLog[]
  apiKeys      ApiKey[]

  @@map("users")
}

// ─── Plans & Purchases ───

model Plan {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  description   String   @default("")
  price         Float
  originalPrice Float?   @map("original_price")                  // strikethrough price (e.g. 799)
  currency      String   @default("₹")
  durationDays  Int      @map("duration_days")                   // 30 = monthly, 365 = yearly
  badge         String   @default("")                            // "20 SPOTS", "After 20 users"
  subtitle      String   @default("")                            // "Locked price for first 20 members"
  features      Json     @default("[]")                          // [{ text, included, addon? }]
  maxApps       Int      @default(0) @map("max_apps")            // 0 = unlimited
  maxAds        Int      @default(0) @map("max_ads")             // 0 = unlimited
  maxSpots      Int?     @map("max_spots")                       // null = unlimited
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  purchases Purchase[]

  @@map("plans")
}

model Purchase {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  planId       Int       @map("plan_id")
  assignedById Int?      @map("assigned_by_id")
  amount       Float
  note         String    @default("")                            // admin remark e.g. "Paid ₹499 via UPI on 20 Mar 2026"
  status       String    @default("active") // "active" | "expired" | "cancelled"
  purchasedAt  DateTime  @default(now()) @map("purchased_at")
  expiresAt    DateTime  @map("expires_at")
  cancelledAt  DateTime? @map("cancelled_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user       User  @relation("UserPurchases", fields: [userId], references: [id], onDelete: Cascade)
  plan       Plan  @relation(fields: [planId], references: [id], onDelete: Restrict)
  assignedBy User? @relation("AssignedByAdmin", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("purchases")
}

// ─── Activity Tracking ───

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  action    String   // "login" | "purchase" | "plan_change" | "account_created" | etc.
  details   String   @default("")
  ipAddress String   @default("") @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Announcements ───

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String   @default("info") // "info" | "update" | "warning"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("announcements")
}

// ─── API Keys & Apps ───

model ApiKey {
  id          Int          @id @default(autoincrement())
  userId      Int?         @map("user_id")
  key         String       @unique
  appName     String       @map("app_name")
  packageName String       @default("") @map("package_name")
  isActive    Boolean      @default(true) @map("is_active")
  suspendedAt DateTime?    @map("suspended_at")                  // set when purchase expires
  createdAt   DateTime     @default(now()) @map("created_at")

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  ads         Ad[]
  pinConfig   PinConfig?
  userPins    UserPin[]
  impressions Impression[]
  clicks      Click[]

  @@index([userId])
  @@map("api_keys")
}

model Ad {
  id                  Int          @id @default(autoincrement())
  apiKeyId            Int          @map("api_key_id")
  title               String
  description         String       @default("")
  imageUrl            String       @default("") @map("image_url")
  redirectUrl         String       @default("") @map("redirect_url")
  adType              String       @default("card") @map("ad_type")        // "fullscreen" | "card" | "banner"
  buttonText          String       @default("Visit Now") @map("button_text")
  isActive            Boolean      @default(true) @map("is_active")
  priority            Int          @default(0)
  maxImpressions      Int          @default(0) @map("max_impressions")     // 0 = unlimited per device
  broadcastToVerified Boolean      @default(false) @map("broadcast_to_verified") // show to already-verified users on return
  targetAudience      String       @default("all") @map("target_audience")       // "all" | "verified" | "unverified"
  scheduledAt         DateTime?    @map("scheduled_at")                           // null = normal, timestamp = push at that time
  createdAt           DateTime     @default(now()) @map("created_at")

  apiKey      ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  impressions Impression[]
  clicks      Click[]

  @@map("ads")
}

model PinConfig {
  id            Int     @id @default(autoincrement())
  apiKeyId      Int     @unique @map("api_key_id")
  pinEnabled    Boolean @default(false) @map("pin_enabled")
  pinMessage    String  @default("Enter PIN to unlock") @map("pin_message")
  maxAttempts   Int     @default(3) @map("max_attempts")
  getPinUrl     String  @default("") @map("get_pin_url")
  getPinBtnText   String  @default("Get PIN") @map("get_pin_btn_text")
  enterPinBtnText String  @default("Enter PIN") @map("enter_pin_btn_text")
  expiryMode    String  @default("never") @map("expiry_mode") // "never" | "duration"
  expiryHours   Int     @default(24) @map("expiry_hours")     // hours until PIN expires (used when expiryMode = "duration")
  tutorialUrl   String  @default("https://t.me/EllieTutorials/36") @map("tutorial_url")
  pinInfoItems  Json    @default("[]") @map("pin_info_items")
  joinLinks     Json    @default("[]") @map("join_links")

  apiKey        ApiKey  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@map("pin_configs")
}

// Each user/device gets a unique PIN — bound to Android ID at generation
model UserPin {
  id        Int       @id @default(autoincrement())
  apiKeyId  Int       @map("api_key_id")
  deviceId  String    @map("device_id")
  pin       String
  isUsed    Boolean   @default(false) @map("is_used")
  createdAt DateTime  @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime? @map("expires_at") // null = never expires

  apiKey    ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, deviceId, pin])
  @@index([apiKeyId, deviceId])
  @@map("user_pins")
}

model GlobalSettings {
  id              Int      @id @default(1)
  pinUnlockMode   String   @default("per_app") @map("pin_unlock_mode") // "per_app" | "global" | "global_except"
  excludedAppIds  Int[]    @default([]) @map("excluded_app_ids")        // apiKey IDs excluded from global unlock
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("global_settings")
}

model Impression {
  id        Int      @id @default(autoincrement())
  adId      Int      @map("ad_id")
  apiKeyId  Int      @map("api_key_id")
  deviceId  String   @default("") @map("device_id")
  createdAt DateTime @default(now()) @map("created_at")

  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([adId, deviceId])
  @@map("impressions")
}

model Click {
  id        Int      @id @default(autoincrement())
  adId      Int      @map("ad_id")
  apiKeyId  Int      @map("api_key_id")
  deviceId  String   @default("") @map("device_id")
  createdAt DateTime @default(now()) @map("created_at")

  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@map("clicks")
}
